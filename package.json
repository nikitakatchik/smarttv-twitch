{
  "name": "twellie",
  "version": "4.0.2",
  "private": true,
  "description": "Twellie - independent TV client for watching Twitch streams on supported Samsung Smart TV platforms, with Orsay, Tizen, TizenBrew, and browser builds.",
  "keywords": [
    "twellie",
    "smart-tv",
    "samsung-tv",
    "tizen",
    "orsay",
    "tv-client",
    "livestreaming",
    "twitch"
  ],
  "homepage": "https://github.com/nkatchik/smarttv-twitch#readme",
  "bugs": "https://github.com/nkatchik/smarttv-twitch/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/nkatchik/smarttv-twitch.git"
  },
  "license": "GPL-3.0-or-later",
  "author": "Nikita Katchik",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node tools/dev-server.js",
    "dev": "node tools/dev-server.js",
    "test": "node tools/version.js --check && node --test test/*.test.js",
    "lint": "node tools/lint-es5.js",
    "version:check": "node tools/version.js --check",
    "version:set": "node tools/version.js",
    "build": "node tools/build.js",
    "build:orsay": "node tools/build.js orsay",
    "build:tizen": "node tools/build.js tizen",
    "build:web": "node tools/build.js web",
    "build:tizenbrew": "node tools/build.js tizenbrew",
    "host": "node tools/host.js",
    "host:package": "node tools/bin.js",
    "tizen:setup": "node tools/tizen-setup.js",
    "release": "node tools/publish.js --build-only",
    "release:publish": "node tools/publish.js"
  },
  "devDependencies": {}
}
